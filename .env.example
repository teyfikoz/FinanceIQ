# FundPilot production environment template

# Core app
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=replace_with_long_random_secret

# Public app identity
FINANCEIQ_APP_DISPLAY_NAME=FundPilot
FINANCEIQ_SUPPORT_EMAIL=techsyncanalytica@gmail.com
FINANCEIQ_PUBLIC_APP_URL=https://fundpilot.techsyncanalytica.com
FINANCEIQ_REQUIRE_AUTH=false
FINANCEIQ_DIRECT_ACCESS=true
FINANCEIQ_CREATE_DEMO_USER=false

# Data providers
FRED_API_KEY=your_fred_key_here
TCMB_EVDS_API_KEY=your_tcmb_evds_key_here
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FMP_API_KEY=your_fmp_key_here
POLYGON_API_KEY=your_polygon_key_here
TRADINGECONOMICS_KEY=your_tradingeconomics_key_here
NEWSAPI_KEY=your_newsapi_key_here
COINGECKO_API_KEY=your_coingecko_key_here
TWELVEDATA_API_KEY=your_twelvedata_key_here
TREASURY_FISCALDATA_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service

# Optional trading integrations
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET_KEY=your_binance_secret_here

# Persistence
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_database_password
POSTGRES_DB=liquidity_dashboard
REDIS_URL=redis://localhost:6379/0

# Alerts
ALERT_EMAIL=alerts@example.com
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=replace_with_smtp_password
